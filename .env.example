# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# LangSmith — tracing for Anthropic SDK calls (no LangChain required)
# Sign up at https://smith.langchain.com to get an API key.
# Set LANGSMITH_TRACING=true to enable; omit or set to false to disable.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
# Optional: override the default project name shown in LangSmith UI
# LANGSMITH_PROJECT=klar-advisory

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# JWT / Auth
JWT_SECRET=your_jwt_secret

# Optional tuning
# ANTHROPIC_MAX_OUTPUT_TOKENS=4000
# ANTHROPIC_TIMEOUT_SECONDS=45
# DIAGNOSTIC_MAX_INPUT_CHARS=8000
