# Klar Backend — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_OUTPUT_TOKENS=4000
ANTHROPIC_TIMEOUT_SECONDS=45
ANTHROPIC_INPUT_USD_PER_MTOK=3
ANTHROPIC_OUTPUT_USD_PER_MTOK=15
DIAGNOSTIC_MAX_INPUT_CHARS=8000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
ADMIN_API_TOKEN=replace-with-a-long-random-admin-bearer-token
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/klar
N8N_WEBHOOK_TIMEOUT_SECONDS=10
N8N_APPROVAL_WEBHOOK_URL=
ADMIN_URL=https://klar-advisory.vercel.app

# Stripe payments
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
FRONTEND_URL=https://klar-advisory.vercel.app

# Resend transactional email
# Note: RESEND_FROM_EMAIL must be a domain verified in your Resend account
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=noreply@your-verified-domain.com

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=<your real key from smith.langchain.com>
LANGSMITH_PROJECT=klar-advisory   # optional, otherwise traces land under "default"
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com